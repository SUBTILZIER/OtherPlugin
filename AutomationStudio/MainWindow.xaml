<Window x:Class="AutomationStudioWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:graph="clr-namespace:AutomationStudioWpf.Graph"
        xmlns:logging="clr-namespace:AutomationStudioWpf.Logging"
        mc:Ignorable="d"
        Title="自动化蓝图编辑器"
        Width="1680"
        Height="980"
        WindowStartupLocation="CenterScreen"
        Background="#181B20"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
    <Window.Resources>
        <Style x:Key="ContentRenameTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Background" Value="#E6EDF5" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="BorderBrush" Value="#4FA3FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="3,1" />
            <Setter Property="TextAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DarkContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#1B2028" />
            <Setter Property="BorderBrush" Value="#303744" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E8EDF5" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type Separator}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1" Margin="8,4" Background="#303744" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ContentFolderToggleIconStyle" TargetType="{x:Type Path}">
            <Setter Property="Data" Value="M 0 0 L 6 4 L 0 8 Z" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTreeExpanded}" Value="True">
                    <Setter Property="Data" Value="M 0 0 L 8 0 L 4 6 Z" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#E8EDF5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="MenuItemBorder"
                                Background="{TemplateBinding Background}"
                                MinWidth="{TemplateBinding MinWidth}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#30445C" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6E7785" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#30445C" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#6E7785" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GraphItemDirtyGlyphStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="#D68A22" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="ToolTip" Value="图表已修改" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDirty}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DarkDropdownListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="#E8EDF5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#263241" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#30455F" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkDropdownListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Foreground" Value="#E8EDF5" />
            <Setter Property="Background" Value="#1B2028" />
            <Setter Property="BorderBrush" Value="#3A4554" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkDropdownListBoxItemStyle}" />
        </Style>
    </Window.Resources>
    <DockPanel>
        <ToolBar DockPanel.Dock="Top"
                 Background="#20242B"
                 BorderBrush="#2E3440"
                 BorderThickness="0,0,0,1"
                 Padding="6">
            <Button Content="新建图谱" Margin="2" Padding="10,4" Click="NewGraph_Click" />
            <Button Content="打开图谱" Margin="2" Padding="10,4" Click="OpenGraph_Click" />
            <Button Content="保存" Margin="2" Padding="10,4" Click="SaveGraph_Click" />
            <Button Content="另存为" Margin="2" Padding="10,4" Click="SaveGraphAs_Click" />
            <Button x:Name="CompileGraphButton" Margin="2" Padding="10,4" Click="CompileGraph_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚙" Margin="0,0,4,0" />
                    <TextBlock x:Name="CompileButtonText" Text="编译" />
                    <Border x:Name="CompileDirtyIcon"
                            Width="14"
                            Height="14"
                            Margin="5,0,0,0"
                            CornerRadius="7"
                            Background="#D68A22"
                            Visibility="Collapsed">
                        <TextBlock Text="!" Foreground="#111111" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Button>
            <Button x:Name="RunGraphButton" Content="执行图谱" Margin="2" Padding="10,4" Click="RunGraph_Click" />
        </ToolBar>

        <Border x:Name="EditorWindowBar"
                DockPanel.Dock="Top"
                MinHeight="34"
                Background="#171B21"
                BorderBrush="#2E3440"
                BorderThickness="0,0,0,1"
                Visibility="Collapsed">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding MainEditorSessions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4,4,0,4"
                                    Padding="10,4"
                                    MinWidth="136"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Cursor="Hand"
                                    PreviewMouseLeftButtonDown="EditorSessionTab_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="EditorSessionTab_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="EditorSessionTab_PreviewMouseLeftButtonUp">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#20242B" />
                                        <Setter Property="BorderBrush" Value="#303744" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="#30445C" />
                                                <Setter Property="BorderBrush" Value="#5EA2E8" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.ContextMenu>
                                    <ContextMenu Style="{StaticResource DarkContextMenuStyle}"
                                                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="关闭窗口" Click="EditorSessionCloseMenuItem_Click" />
                                        <MenuItem Header="独立窗口" Click="EditorSessionDetachMenuItem_Click" />
                                        <Separator />
                                        <MenuItem Header="关闭所有窗口" Click="EditorSessionCloseAllMenuItem_Click" />
                                        <MenuItem Header="关闭右侧窗口" Click="EditorSessionCloseRightMenuItem_Click" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Content="x"
                                            Width="20"
                                            Height="20"
                                            Padding="0"
                                            Margin="8,0,0,0"
                                            Click="EditorSessionCloseButton_Click" />
                                    <Border DockPanel.Dock="Left"
                                            Width="8"
                                            Height="8"
                                            Margin="0,0,7,0"
                                            CornerRadius="4"
                                            Background="#D68A22">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               Foreground="#E8EDF5"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="LogRow" Height="360" MinHeight="180" />
            </Grid.RowDefinitions>

            <ContentControl x:Name="EditorSurfaceHostRoot"
                            Grid.Row="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Visibility="Collapsed" />
            <Border x:Name="EmptyEditorPanel"
                    Grid.Row="0"
                    Margin="10"
                    Background="#11151A"
                    BorderBrush="#303744"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="内容浏览器"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="请从底部内容浏览器打开脚本、函数库或宏库。"
                               Foreground="#9AA4B2"
                               FontSize="14"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <GridSplitter Grid.Row="1"
                          Height="4"
                          HorizontalAlignment="Stretch"
                          Background="#2E3440"
                          ResizeDirection="Rows" />

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="360" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="360" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#15191F"
                        BorderBrush="#2E3440"
                        BorderThickness="0,1,1,0">
                    <DockPanel>
                        <StackPanel x:Name="ContentBrowserHeaderBar" DockPanel.Dock="Top" Orientation="Horizontal" Background="#20242B" Height="30">
                            <TextBlock Text="内容浏览器" Foreground="White" FontWeight="SemiBold" Margin="10,0,8,0" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                        <Grid x:Name="ContentBrowserBodyGrid" PreviewMouseDown="ContentBrowserArea_PreviewMouseDown">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ContentTreeColumn" Width="180" MinWidth="120" MaxWidth="420" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="240" />
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="ContentFolderListBox"
                                     ItemsSource="{Binding ContentFolderItems}"
                                     Background="#11151A"
                                     BorderThickness="0,0,1,0"
                                     BorderBrush="#2E3440"
                                     Foreground="White"
                                     AllowDrop="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     KeyDown="ContentFolderListBox_KeyDown"
                                     MouseDoubleClick="ContentFolderListBox_MouseDoubleClick"
                                     PreviewMouseDown="ContentBrowserArea_PreviewMouseDown">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="4,2" />
                                        <Setter Property="Padding" Value="6,5" />
                                        <Setter Property="AllowDrop" Value="True" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ContentFolderItem_PreviewMouseLeftButtonDown" />
                                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="ContentFolder_PreviewMouseRightButtonDown" />
                                        <EventSetter Event="DragEnter" Handler="ContentFolder_DragEnter" />
                                        <EventSetter Event="Drop" Handler="ContentFolder_Drop" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid x:Name="ContentFolderTreeRow" Margin="{Binding TreeIndent}" MinHeight="22">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="ContentFolderToggleButton"
                                                    Width="16"
                                                    Height="18"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Click="ContentFolderToggle_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="{x:Type Button}">
                                                        <Border Background="{TemplateBinding Background}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Style>
                                                    <Style TargetType="{x:Type Button}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasFolderChildren}" Value="False">
                                                                <Setter Property="Visibility" Value="Hidden" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Path x:Name="ContentFolderToggleIcon"
                                                      Width="8"
                                                      Height="8"
                                                      Stretch="Uniform"
                                                      Fill="#8FA0B5"
                                                      Style="{StaticResource ContentFolderToggleIconStyle}" />
                                            </Button>
                                            <Grid Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                         KeyDown="ContentAssetNameTextBox_KeyDown"
                                                         LostFocus="ContentAssetNameTextBox_LostFocus"
                                                         Style="{StaticResource ContentRenameTextBoxStyle}" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ContextMenu>
                                    <ContextMenu Style="{StaticResource DarkContextMenuStyle}">
                                        <MenuItem Header="重命名" Click="RenameContentAssetMenuItem_Click" />
                                        <MenuItem Header="删除" Click="DeleteContentAssetMenuItem_Click" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                            </ListBox>
                            <GridSplitter x:Name="ContentBrowserTreeSplitter"
                                          Grid.Column="1"
                                          Width="4"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Background="#2E3440"
                                          ShowsPreview="True"
                                          ResizeBehavior="PreviousAndNext" />
                             <ListBox x:Name="ContentBrowserListBox"
                                  Grid.Column="2"
                                  ItemsSource="{Binding ContentVisibleItems}"
                                  Background="#15191F"
                                  BorderThickness="0"
                                  Foreground="White"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="False"
                                  KeyDown="ContentBrowserListBox_KeyDown"
                                  MouseDoubleClick="ContentBrowserListBox_MouseDoubleClick"
                                  PreviewMouseDown="ContentBrowserArea_PreviewMouseDown"
                                  PreviewMouseRightButtonDown="ContentBrowserListBox_PreviewMouseRightButtonDown"
                                  PreviewMouseMove="ContentBrowserListBox_PreviewMouseMove">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True"
                                               Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Width" Value="94" />
                                    <Setter Property="Height" Value="96" />
                                    <Setter Property="Margin" Value="6" />
                                    <Setter Property="Padding" Value="6" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="Foreground" Value="White" />
                                     <Setter Property="Background" Value="Transparent" />
                                     <Setter Property="AllowDrop" Value="True" />
                                     <EventSetter Event="PreviewMouseRightButtonDown" Handler="ContentAsset_PreviewMouseRightButtonDown" />
                                    <EventSetter Event="DragEnter" Handler="ContentFolder_DragEnter" />
                                    <EventSetter Event="Drop" Handler="ContentFolder_Drop" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#30445C" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2B3542" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Border Width="44" Height="40" CornerRadius="6" Background="{Binding TileBrush}" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding TileGlyph}" Foreground="{Binding TileGlyphForeground}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 KeyDown="ContentAssetNameTextBox_KeyDown"
                                                 LostFocus="ContentAssetNameTextBox_LostFocus"
                                                 Style="{StaticResource ContentRenameTextBoxStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ContextMenu>
                                <ContextMenu Style="{StaticResource DarkContextMenuStyle}"
                                             Opened="ContentBrowserContextMenu_Opened">
                                    <MenuItem x:Name="ContentBrowserRenameMenuItem" Header="重命名" Click="RenameContentAssetMenuItem_Click" />
                                    <MenuItem x:Name="ContentBrowserDeleteMenuItem" Header="删除" Click="DeleteContentAssetMenuItem_Click" />
                                    <Separator x:Name="ContentBrowserAssetMenuSeparator" />
                                    <MenuItem x:Name="ContentBrowserNewScriptMenuItem" Header="脚本" Click="NewScriptAsset_Click" />
                                    <MenuItem x:Name="ContentBrowserNewFolderMenuItem" Header="文件夹" Click="NewContentFolder_Click" />
                                    <Separator x:Name="ContentBrowserNewLibraryMenuSeparator" />
                                    <MenuItem x:Name="ContentBrowserNewFunctionLibraryMenuItem" Header="函数库" Click="NewFunctionLibraryAsset_Click" />
                                    <MenuItem x:Name="ContentBrowserNewMacroLibraryMenuItem" Header="宏库" Click="NewMacroLibraryAsset_Click" />
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            </ListBox>
                        </Grid>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Stretch"
                              Background="#2E3440"
                              ResizeDirection="Columns" />

                <Border Grid.Column="2"
                    Background="#11151A"
                    BorderBrush="#2E3440"
                    BorderThickness="0,1,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#20242B" Height="26">
                        <TextBlock Text="日志" Foreground="White" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12" />
                        <TextBlock x:Name="StatusTextBlock" Foreground="#7A8797" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="11" />
                        <Border Margin="10,0,0,0" Background="#2E3440" Height="18" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="FilterAllRadio" Content="全部" IsChecked="True" Checked="FilterRadio_Checked" Margin="4,0" Padding="6,0" FontSize="11" Foreground="#D0D7E2" />
                                <RadioButton x:Name="FilterInfoRadio" Content="信息" Checked="FilterRadio_Checked" Margin="4,0" Padding="6,0" FontSize="11" Foreground="#D0D7E2" />
                                <RadioButton x:Name="FilterWarnRadio" Content="警告" Checked="FilterRadio_Checked" Margin="4,0" Padding="6,0" FontSize="11" Foreground="#FFD700" />
                                <RadioButton x:Name="FilterErrorRadio" Content="错误" Checked="FilterRadio_Checked" Margin="4,0" Padding="6,0" FontSize="11" Foreground="#FF6B6B" />
                            </StackPanel>
                        </Border>
                        <Button Content="清空" Click="ClearLog_Click" Margin="8,2,8,2" Padding="8,2" Height="20" FontSize="11" />
                    </StackPanel>

                    <RichTextBox x:Name="LogRichTextBox"
                                 Background="#11151A"
                                 Foreground="#D0D7E2"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 IsReadOnly="True"
                                 Padding="6,4"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto" />
                </DockPanel>
            </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
