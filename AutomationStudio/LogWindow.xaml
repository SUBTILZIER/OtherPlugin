<Window x:Class="AutomationStudioWpf.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:logging="clr-namespace:AutomationStudioWpf.Logging"
        Title="日志"
        Width="900"
        Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1F22">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="10,8"
                    Background="Transparent">
            <Button Content="复制全部" Click="CopyAll_Click" Margin="0,0,8,0" Padding="12,4" />
            <Button Content="清空" Click="Clear_Click" Padding="12,4" />
            <Border Margin="8,0,0,0" Background="#2E3440" CornerRadius="3" Height="22" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="FilterAllRadio" Content="全部" IsChecked="True"
                                 Checked="FilterRadio_Checked"
                                 Margin="4,0" Padding="6,0" FontSize="11"
                                 Foreground="#D0D7E2" />
                    <RadioButton x:Name="FilterInfoRadio" Content="信息"
                                 Checked="FilterRadio_Checked"
                                 Margin="4,0" Padding="6,0" FontSize="11"
                                 Foreground="#D0D7E2" />
                    <RadioButton x:Name="FilterWarnRadio" Content="警告"
                                 Checked="FilterRadio_Checked"
                                 Margin="4,0" Padding="6,0" FontSize="11"
                                 Foreground="#FFD700" />
                    <RadioButton x:Name="FilterErrorRadio" Content="错误"
                                 Checked="FilterRadio_Checked"
                                 Margin="4,0" Padding="6,0" FontSize="11"
                                 Foreground="#FF6B6B" />
                </StackPanel>
            </Border>
            <TextBlock x:Name="LogDirText"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="#7A8797"
                       FontSize="11" />
        </StackPanel>
        <RichTextBox x:Name="LogRichTextBox"
                     Background="#11151A"
                     Foreground="#D0D7E2"
                     BorderThickness="0"
                     Margin="10,0,10,10"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     Padding="6,4"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" />
    </DockPanel>
</Window>
