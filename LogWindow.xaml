<Window x:Class="AutomationStudioWpf.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="日志"
        Width="900"
        Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1F22">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="10,8"
                    Background="Transparent">
            <Button Content="复制全部" Click="CopyAll_Click" Margin="0,0,8,0" Padding="12,4" />
            <Button Content="清空" Click="Clear_Click" Padding="12,4" />
            <TextBlock x:Name="LogDirText"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="#7A8797"
                       FontSize="11" />
        </StackPanel>
        <TextBox x:Name="LogTextBox"
                 IsReadOnly="True"
                 Background="#11151A"
                 Foreground="#D0D7E2"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="12"
                 Margin="10,0,10,10"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" />
    </DockPanel>
</Window>
